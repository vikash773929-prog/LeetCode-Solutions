class Solution {
public:
    int vowelConsonantScore(string s) {
         int v = 0, c = 0;

        for (char ch : s) {
            if (isalpha(ch)) {
                if (ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u')
                    v++;
                else
                    c++;
            }
        }

        return c ? v / c : 0;
    }
};
